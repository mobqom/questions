{
    "consumes": [
        "application/json"
    ],
    "produces": [
        "application/json"
    ],
    "swagger": "2.0",
    "info": {
        "description": "API для работы с вопросами",
        "title": "Questions API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/questions",
    "paths": {
        "/options/add-option": {
            "post": {
                "description": "Создает новый вариант ответа для вопроса",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "options"
                ],
                "summary": "Добавить новый вариант ответа",
                "parameters": [
                    {
                        "description": "Объект варианта ответа",
                        "name": "option",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.AddOptionDto"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/domain.Option"
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/options/find-all": {
            "get": {
                "description": "Возвращает список всех вариантов ответов из базы данных",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "options"
                ],
                "summary": "Получить все варианты ответов",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.Option"
                            }
                        }
                    }
                }
            }
        },
        "/options/{questionId}": {
            "get": {
                "description": "Возвращает список всех вариантов ответов для конкретного вопроса",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "options"
                ],
                "summary": "Получить варианты ответов для вопроса",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID вопроса",
                        "name": "questionId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.Option"
                            }
                        }
                    }
                }
            }
        },
        "/questions/add-question": {
            "post": {
                "description": "Создает новый вопрос в базе данных",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "questions"
                ],
                "summary": "Добавить новый вопрос",
                "parameters": [
                    {
                        "description": "Объект вопроса",
                        "name": "question",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.AddQuestionDto"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/domain.Question"
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/questions/find-all": {
            "get": {
                "description": "Возвращает список всех вопросов из базы данных",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "questions"
                ],
                "summary": "Получить все вопросы",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.Question"
                            }
                        }
                    }
                }
            }
        },
        "/questions/find-by-game": {
            "get": {
                "description": "Возвращает список всех вопросов для конкретной игры",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "questions"
                ],
                "summary": "Получить вопросы по ID игры",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID игры",
                        "name": "gameId",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.Question"
                            }
                        }
                    }
                }
            }
        },
        "/questions/random": {
            "get": {
                "description": "Возвращает случайный вопрос из базы данных",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "questions"
                ],
                "summary": "Получить случайный вопрос",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID игры",
                        "name": "gameId",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Тип вопроса",
                        "name": "type",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Количество вопросов",
                        "name": "count",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.Question"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.Option": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "question_id": {
                    "type": "integer"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "domain.Question": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "type": "string"
                },
                "game": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "options": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/domain.Option"
                    }
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "dto.AddOptionDto": {
            "type": "object",
            "required": [
                "content",
                "question_id"
            ],
            "properties": {
                "content": {
                    "type": "string"
                },
                "question_id": {
                    "type": "integer"
                }
            }
        },
        "dto.AddQuestionDto": {
            "type": "object",
            "required": [
                "content",
                "game"
            ],
            "properties": {
                "content": {
                    "type": "string"
                },
                "game": {
                    "type": "string"
                }
            }
        }
    }
}